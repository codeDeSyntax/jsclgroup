# Frontend environment variables
# Preferred: set NEXT_PUBLIC_BACKEND_URL explicitly in each environment
# or set per-environment values below

# Optional: explicit backend URL used regardless of NODE_ENV
# NEXT_PUBLIC_BACKEND_URL=https://api.example.com

# Optional: per-environment fallbacks used when NEXT_PUBLIC_BACKEND_URL is not set
NEXT_PUBLIC_PROD_BACKEND_URL=https://api.example.com
NEXT_PUBLIC_DEV_BACKEND_URL=http://localhost:4000
